{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "blank",
  "version": "1.1.0",
  "identifier": "com.github.fpurchess.blank",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Blank",
        "width": 800,
        "height": 600,
        "decorations": true,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "cli": {
      "description": "Blank is a minimalist, opinionated markdown editor made for writing",
      "args": [
        {
          "name": "path",
          "description": "The file path to open",
          "index": 1,
          "takesValue": true,
          "required": false
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}