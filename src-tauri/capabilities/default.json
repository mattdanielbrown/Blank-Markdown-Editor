{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "fs:default",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "/**" }]
    },
    {
      "identifier": "fs:write-all",
      "allow": [{ "path": "/**" }]
    },
    {
      "identifier": "fs:read-all",
      "allow": [{ "path": "/**" }]
    }
  ]
}